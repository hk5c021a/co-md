# =============================================================================
# CO-MD 环境配置模板
# =============================================================================
# 复制此文件并填入实际值：
#   开发: cp .env.example .env.dev.local
#   生产: cp .env.example .env.prod.local
# 注意: *.local 文件不提交到 Git（已在 .gitignore 中排除）
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 一、Docker 基础设施（docker-compose.yml 使用 ${VAR} 插值）
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RustFS (S3 兼容对象存储)
RUSTFS_USER=
RUSTFS_PASSWORD=
RUSTFS_PORT=9000

# 生产域名（Caddy TLS 自动签发 Let's Encrypt 证书）
DOMAIN=
# Let's Encrypt 证书续期通知邮箱（生产推荐填写）
ACME_EMAIL=admin@example.com

# 容器重启策略: unless-stopped | always | no | on-failure
RESTART_POLICY=unless-stopped

# ─────────────────────────────────────────────────────────────────────────────
# 二、后端服务（apps/backend）
# ─────────────────────────────────────────────────────────────────────────────

# 运行模式: development | production
NODE_ENV=development

# 监听端口（默认 3000）
PORT=3000

# PostgreSQL 连接（生产环境建议追加 ?sslmode=require）
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/collab_db

# Redis 连接
REDIS_URL=redis://:redis_password@localhost:6379

# JWT 签名密钥（至少 32 字符，使用 openssl rand -hex 32 生成）
JWT_SECRET=

# 服务间 API 密钥（内部端点认证，生产环境必须更换）
INTERNAL_API_SECRET=

# RustFS / S3 对象存储
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_BUCKET=collab-files
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=

# SMTP 邮件服务（密码重置等）
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@collab.local

# CORS 允许的来源（必须包含协议前缀，如 http:// 或 https://）
CORS_ORIGIN=http://localhost:5173

# 密码重置邮件中的链接基础 URL
PASSWORD_RESET_BASE_URL=http://localhost:5173

# 开发模式标志（true = 代理到 Vite 开发服务器，false = 服务静态构建文件）
VITE_DEV=true

# 日志级别（debug | info | warn | error，生产默认 info）
LOG_LEVEL=info

# 启动时运行数据库迁移（默认 true，设为 false 跳过）
# MIGRATE_ON_STARTUP=true

# OpenTelemetry 链路追踪（可选，留空禁用）
OTEL_SERVICE_NAME=collab-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# 文件上传限制（可选，使用默认值）
# UPLOAD_MAX_SIZE=10485760
# UPLOAD_MAX_FILES_PER_DOC=50
# UPLOAD_MAX_STORAGE_PER_USER=104857600

# ─────────────────────────────────────────────────────────────────────────────
# 三、WebSocket 服务（apps/ws-server）
# ─────────────────────────────────────────────────────────────────────────────

# WebSocket 服务端口（默认 4000）
WS_PORT=4000

# 后端内部 API 地址（WS 服务用于权限校验和通知转发）
BACKEND_URL=http://localhost:3000

# WS 服务也使用:
#   - REDIS_URL (同上)
#   - CORS_ORIGIN (同上)
#   - JWT_SECRET (同上)
#   - INTERNAL_API_SECRET (同上)

# ─────────────────────────────────────────────────────────────────────────────
# 四、前端（apps/frontend，变量须以 VITE_ 为前缀）
# ─────────────────────────────────────────────────────────────────────────────

# API 基础 URL（开发直连后端，生产留空使用同源相对路径）
VITE_API_URL=https://localhost:3000

# WebSocket URL（开发直连 WS 服务，生产留空使用 location.host/ws-server）
VITE_WS_URL=wss://localhost:4000
