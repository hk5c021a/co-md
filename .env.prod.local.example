# =============================================================================
# CO-MD 生产环境配置 — 模板文件 (EXAMPLE)
# =============================================================================
# 用途: 将此文件复制为 .env.prod.local 并填入真实值
# 命令: copy .env.prod.local.example .env.prod.local
# 注意: .env.prod.local 不提交到 Git，包含生产密钥和凭据
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 一、Docker 基础设施
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=collab_db
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

RUSTFS_USER=rustfsadmin
RUSTFS_PASSWORD=CHANGE_ME_RUSTFS_PASSWORD
RUSTFS_PORT=9000

# 生产域名（Caddy 自动签发 Let's Encrypt TLS 证书）
DOMAIN=CHANGE_ME_YOUR_DOMAIN

# Let's Encrypt 证书续期通知邮箱（必须设置）
ACME_EMAIL=CHANGE_ME_YOUR_EMAIL

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

RESTART_POLICY=always

# ─────────────────────────────────────────────────────────────────────────────
# 二、后端服务
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/collab_db
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# JWT 密钥 — 使用 openssl rand -hex 32 生成
JWT_SECRET=CHANGE_ME_JWT_SECRET
# JWT 刷新令牌独立密钥（可选，默认复用 JWT_SECRET）
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET

# 服务间 API 密钥 — 使用 openssl rand -hex 32 生成
INTERNAL_API_SECRET=CHANGE_ME_INTERNAL_API_SECRET

# RustFS 存储（容器内使用 service name 通信）
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_BUCKET=collab-files
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=CHANGE_ME_RUSTFS_PASSWORD

# SMTP 邮件服务 — 使用真实邮件服务（如 Resend / AWS SES / 自建）
SMTP_HOST=CHANGE_ME_SMTP_HOST
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASS
SMTP_FROM=noreply@CHANGE_ME_YOUR_DOMAIN_COM

# CORS — 前端访问的生产域名（含 https:// 前缀）
CORS_ORIGIN=https://CHANGE_ME_YOUR_DOMAIN_COM

# 密码重置邮件中的链接基础 URL
PASSWORD_RESET_BASE_URL=https://CHANGE_ME_YOUR_DOMAIN_COM

# 生产模式：后端直接服务前端静态构建文件
VITE_DEV=false

# OpenTelemetry（可选）
OTEL_SERVICE_NAME=collab-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# ─────────────────────────────────────────────────────────────────────────────
# 三、WebSocket 服务
# ─────────────────────────────────────────────────────────────────────────────

# WS 服务内部端口（Caddy 代理到 /ws-server）
WS_PORT=4000

# 后端内部 API 地址（容器内通过 service name 通信，使用 HTTP 非 TLS）
BACKEND_URL=http://backend:3000

# ─────────────────────────────────────────────────────────────────────────────
# 四、前端
# ─────────────────────────────────────────────────────────────────────────────

# 生产环境 Vite 构建时内嵌: API/WS 留空走同源相对路径
VITE_API_URL=
VITE_WS_URL=
