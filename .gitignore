# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
coverage/
test-results/
apps/reports/

# Turbo
.turbo/

# Temporary files
*.tmp
*.temp

# Docker volumes (local dev data)
data/

# PWA dev service worker (auto-generated by vite-plugin-pwa in dev mode)
apps/frontend/dev-dist/

# Playwright MCP browser state
.playwright-mcp/

# Local Claude Code settings (per-user, not shared)
.claude/settings.local.json

# Ad-hoc screenshots (debugging artifacts)
/login-*.png
/login-*
/offline-page.png
/qa-login-page.png

# TLS certificates (generated locally by mkcert, do not commit)
certs/*.pem

# Husky internal scripts (auto-generated by husky install)
.husky/_/

# npm lockfile (project uses pnpm)
**/package-lock.json
.claude/scheduled_tasks.lock
lighthouse.html
